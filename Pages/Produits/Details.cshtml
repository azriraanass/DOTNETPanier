@page
@model WebApplication1.Pages.Produits.DetailsModel

@{
    ViewData["Title"] = Model.Produit.Name;
}

<style>
    :root {
        --primary-gradient: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        --primary-color: #764ba2;
        --secondary-bg: #f8f9fa;
        --text-dark: #2d3748;
        --text-muted: #718096;
        --shadow-soft: 0 10px 30px rgba(0,0,0,0.05);
    }

    body {
        background-color: #fcfcfc;
    }

    /* Breadcrumb nav */
    .breadcrumb-nav {
        font-size: 0.9rem;
        margin-bottom: 2rem;
    }
    .breadcrumb-item a {
        color: var(--text-muted);
        text-decoration: none;
        transition: color 0.2s;
    }
    .breadcrumb-item a:hover {
        color: var(--primary-color);
    }

    /* Product Container */
    .product-detail-container {
        background: white;
        border-radius: 30px;
        box-shadow: var(--shadow-soft);
        overflow: hidden;
        padding: 2rem;
    }

    /* Image Section (Left) */
    .img-container {
        position: relative;
        background-color: #f1f3f5;
        border-radius: 20px;
        overflow: hidden;
        height: 500px; /* Fixed height for consistency */
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .img-container img {
        max-width: 100%;
        max-height: 100%;
        object-fit: contain; /* Ensures the whole image is seen */
        transition: transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }

    .img-container:hover img {
        transform: scale(1.05);
    }

    /* Details Section (Right) */
    .product-info {
        padding: 1rem 1rem 1rem 2rem;
        display: flex;
        flex-direction: column;
        height: 100%;
    }

    .category-badge {
        text-transform: uppercase;
        letter-spacing: 1px;
        font-size: 0.75rem;
        font-weight: 700;
        color: var(--primary-color);
        margin-bottom: 0.5rem;
    }

    .product-title {
        font-size: 2.5rem;
        font-weight: 800;
        color: var(--text-dark);
        line-height: 1.2;
        margin-bottom: 1rem;
    }

    .product-price {
        font-size: 2rem;
        font-weight: 700;
        color: var(--primary-color);
        margin-bottom: 1.5rem;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .stock-badge {
        font-size: 0.9rem;
        padding: 5px 12px;
        border-radius: 20px;
        font-weight: 600;
    }
    .stock-in { background: #d1fae5; color: #065f46; }
    .stock-low { background: #ffedd5; color: #9a3412; }
    .stock-out { background: #fee2e2; color: #991b1b; }

    .description-text {
        color: var(--text-muted);
        line-height: 1.7;
        font-size: 1rem;
        margin-bottom: 2.5rem;
        border-top: 1px solid #edf2f7;
        padding-top: 1.5rem;
    }

    /* Actions Area */
    .actions-wrapper {
        margin-top: auto;
        background: #f8fafc;
        padding: 1.5rem;
        border-radius: 20px;
        border: 1px solid #edf2f7;
    }

    .qty-input-group {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 1rem;
    }

    .form-control-qty {
        width: 80px;
        text-align: center;
        border-radius: 10px;
        border: 1px solid #e2e8f0;
        padding: 10px;
        font-weight: 600;
    }

    .btn-add-cart {
        width: 100%;
        background: var(--text-dark);
        color: white;
        border: none;
        padding: 15px;
        border-radius: 12px;
        font-weight: 700;
        font-size: 1.1rem;
        transition: all 0.3s;
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 10px;
    }

    .btn-add-cart:hover:not(:disabled) {
        background: var(--primary-color);
        transform: translateY(-2px);
        box-shadow: 0 10px 20px rgba(118, 75, 162, 0.25);
    }

    .btn-add-cart:disabled {
        background: #cbd5e0;
        cursor: not-allowed;
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .product-detail-container { padding: 1rem; }
        .img-container { height: 300px; margin-bottom: 2rem; }
        .product-info { padding: 0; }
        .product-title { font-size: 1.8rem; }
    }
</style>

<div class="container py-5">
    
    <nav aria-label="breadcrumb" class="breadcrumb-nav">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Home</a></li>
            <li class="breadcrumb-item"><a href="/Produits/Index">Shop</a></li>
            <li class="breadcrumb-item active" aria-current="page">@Model.Produit.Name</li>
        </ol>
    </nav>

    <div class="product-detail-container">
        <div class="row g-0">
            
            <div class="col-lg-6">
                <div class="img-container">
                    @if (!string.IsNullOrEmpty(Model.Produit.ImageUrl))
                    {
                        <img src="@Model.Produit.ImageUrl" alt="@Model.Produit.Name" />
                    }
                    else
                    {
                        <div class="text-center text-muted">
                            <i class="bi bi-image display-1 opacity-25"></i>
                            <p class="mt-2">No image available</p>
                        </div>
                    }
                </div>
            </div>

            <div class="col-lg-6">
                <div class="product-info">
                    
                    <div>
                        <div class="d-flex justify-content-between align-items-start">
                            <span class="category-badge">
                                @(Model.Produit.Category?.Name ?? "General")
                            </span>
                            
                            @if (Model.Produit.Stock > 10) {
                                <span class="stock-badge stock-in"><i class="bi bi-check-circle-fill me-1"></i> In Stock</span>
                            } else if (Model.Produit.Stock > 0) {
                                <span class="stock-badge stock-low"><i class="bi bi-exclamation-circle-fill me-1"></i> Low Stock (@Model.Produit.Stock)</span>
                            } else {
                                <span class="stock-badge stock-out"><i class="bi bi-x-circle-fill me-1"></i> Sold Out</span>
                            }
                        </div>

                        <h1 class="product-title">@Model.Produit.Name</h1>

                        <div class="product-price">
                            @Model.Produit.Price.ToString("N2") <small class="fs-6 text-muted align-self-center mt-1">€</small>
                        </div>
                    </div>

                    <div class="description-text">
                        <p>@Model.Produit.Description</p>
                    </div>

                    <div class="actions-wrapper">
                        <form method="post" asp-page="/Produits/Index" asp-page-handler="AddToCart">
                            <input type="hidden" name="productId" value="@Model.Produit.ProduitId" />
                            <input type="hidden" name="stock" value="@Model.Produit.Stock" />
                            
                            <div class="row align-items-end g-3">
                                <div class="col-4">
                                    <label class="form-label small fw-bold text-muted">Quantity</label>
                                    <input type="number" name="quantity" value="1" min="1" max="@Model.Produit.Stock" 
                                           class="form-control form-control-qty w-100" 
                                           @(Model.Produit.Stock < 1 ? "disabled" : "") />
                                </div>
                                <div class="col-8">
                                    <button type="submit" class="btn-add-cart" @(Model.Produit.Stock < 1 ? "disabled" : "")>
                                        @if(Model.Produit.Stock > 0) {
                                            <span>Add to Cart</span> <i class="bi bi-bag-plus"></i>
                                        } else {
                                            <span>Out of Stock</span>
                                        }
                                    </button>
                                </div>
                            </div>
                        </form>
                        
                        <div class="mt-3 pt-3 border-top d-flex gap-4 text-muted small">
                            <span><i class="bi bi-shield-check me-1"></i> 2 Year Warranty</span>
                            <span><i class="bi bi-truck me-1"></i> Fast Delivery</span>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>

    <div class="mt-4">
        <a asp-page="./Index" class="text-decoration-none fw-bold text-muted hover-primary">
            <i class="bi bi-arrow-left me-2"></i> Back to Shop
        </a>
    </div>
</div>