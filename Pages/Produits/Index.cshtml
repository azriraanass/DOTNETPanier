@page
@model WebApplication1.Pages.Produits.IndexModel

@{
    ViewData["Title"] = "Shop Collection";
}

<style>
    :root {
        --primary-gradient: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        --primary-color: #764ba2;
        --secondary-bg: #f8f9fa;
        --card-shadow: 0 10px 20px rgba(0,0,0,0.05);
        --card-hover-shadow: 0 20px 40px rgba(0,0,0,0.12);
        --glass-bg: rgba(255, 255, 255, 0.9);
    }

    body {
        background-color: #fcfcfc;
        /* Ensure no parent has overflow:hidden for sticky to work */
    }

    /* 1. COMPACT HERO SECTION */
    .hero-section {
        background: var(--primary-gradient);
        color: white;
        padding: 2.5rem 1rem 4.5rem 1rem;
        border-radius: 0 0 30px 30px;
        margin-bottom: 0;
        position: relative;
        overflow: hidden;
    }
    
    .hero-pattern {
        position: absolute;
        top: 0; left: 0; right: 0; bottom: 0;
        opacity: 0.1;
        background-image: radial-gradient(#fff 1px, transparent 1px);
        background-size: 20px 20px;
    }

    .hero-content {
        position: relative;
        z-index: 2;
    }

    .hero-title {
        font-weight: 800;
        font-size: 2rem;
        letter-spacing: -0.5px;
        margin-bottom: 0.2rem;
    }
    
    .hero-subtitle {
        font-size: 1rem;
        opacity: 0.9;
        font-weight: 400;
    }

    /* 2. STICKY FILTER & CART BAR */
    .filter-bar-container {
        margin-top: -2.5rem; 
        margin-bottom: 2.5rem;
        padding: 0 1rem;
        position: sticky;
        top: 15px; /* Distance from top of screen during scroll */
        z-index: 1050;
    }

    .filter-bar {
        background: var(--glass-bg);
        backdrop-filter: blur(15px);
        -webkit-backdrop-filter: blur(15px);
        border: 1px solid rgba(255, 255, 255, 0.5);
        padding: 0.75rem 1.25rem;
        border-radius: 16px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
    }

    .form-select-custom {
        border-radius: 12px;
        border: 1px solid #e0e0e0;
        padding: 0.6rem 1rem;
        min-width: 220px;
        font-size: 0.9rem;
        cursor: pointer;
        transition: all 0.2s;
    }

    .form-select-custom:focus {
        border-color: var(--primary-color);
        outline: none;
        box-shadow: 0 0 0 3px rgba(118, 75, 162, 0.1);
    }

    /* 3. PRODUCT CARDS */
    .product-card {
        border: none;
        border-radius: 20px;
        background: white;
        transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
        box-shadow: var(--card-shadow);
        height: 100%;
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    .product-card:hover {
        transform: translateY(-8px);
        box-shadow: var(--card-hover-shadow);
    }

    .img-wrapper {
        position: relative;
        padding-top: 80%;
        overflow: hidden;
        background: #f1f3f5;
    }

    .img-wrapper img {
        position: absolute;
        top: 0; left: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.5s ease;
    }

    .product-card:hover .img-wrapper img {
        transform: scale(1.08);
    }

    /* Overlays */
    .card-badges {
        position: absolute;
        top: 12px;
        left: 12px;
        display: flex;
        flex-direction: column;
        gap: 6px;
        z-index: 10;
    }

    .badge-blur {
        background: rgba(0, 0, 0, 0.6);
        backdrop-filter: blur(4px);
        color: white;
        padding: 4px 10px;
        border-radius: 30px;
        font-size: 0.7rem;
        font-weight: 600;
    }

    .badge-stock {
        background: rgba(255, 255, 255, 0.9);
        color: #333;
    }

    /* Card Details */
    .card-body {
        padding: 1.25rem;
        flex-grow: 1;
        display: flex;
        flex-direction: column;
    }

    .product-title {
        font-weight: 700;
        font-size: 1rem;
        color: #2d3748;
        margin-bottom: 0.4rem;
        height: 2.4rem; /* Fixed height for title alignment */
        overflow: hidden;
    }

    .price-tag {
        font-size: 1.25rem;
        font-weight: 800;
        color: var(--primary-color);
        margin-bottom: 0.8rem;
    }

    .product-desc {
        color: #718096;
        font-size: 0.85rem;
        line-height: 1.4;
        margin-bottom: 1.25rem;
    }

    /* 4. BUTTONS & ACTIONS */
    .card-actions {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-top: auto;
    }

    .qty-input {
        width: 55px;
        text-align: center;
        border: 1px solid #e2e8f0;
        border-radius: 10px;
        padding: 6px;
        font-weight: 600;
        font-size: 0.9rem;
    }

    .btn-add-cart {
        flex-grow: 1;
        background: #2d3748;
        color: white;
        border: none;
        border-radius: 10px;
        padding: 8px;
        font-weight: 600;
        font-size: 0.9rem;
        transition: all 0.2s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 5px;
    }

    .btn-add-cart:hover:not(:disabled) {
        background: var(--primary-color);
        transform: scale(1.02);
    }

    .btn-add-cart:disabled {
        background: #cbd5e0;
        cursor: not-allowed;
    }

    /* 5. RESPONSIVE ADJUSTMENTS */
    @@media (max-width: 768px) {
        .filter-bar {
            flex-direction: column;
            align-items: stretch;
        }
        .form-select-custom {
            min-width: 100%;
        }
        .hero-title {
            font-size: 1.6rem;
        }
    }
</style>

<div class="hero-section text-center">
    <div class="hero-pattern"></div>
    <div class="container hero-content">
        <h1 class="display-4 hero-title">Curated For You</h1>
        <p class="lead" style="opacity: 0.9;">Premium products at unbeatable prices.</p>
    </div>
</div>

<div class="container">
    
    <div class="filter-bar-container">
        <div class="filter-bar">
            <form method="get" class="d-flex align-items-center flex-grow-1 gap-3">
                <div class="d-flex align-items-center gap-2">
                    <i class="bi bi-funnel-fill text-muted"></i>
                    <select id="CategoryId" name="CategoryId" class="form-select-custom" onchange="this.form.submit()">
                        <option value="">All Categories</option>
                        @foreach (var category in Model.Categories)
                        {
                            <option value="@category.CategoryId" selected="@(Model.CategoryId == category.CategoryId)">
                                @category.Name
                            </option>
                        }
                    </select>
                </div>
                </form>

            <a asp-page="/Panier/Index" class="btn btn-dark rounded-pill px-4 py-2 fw-bold d-flex align-items-center gap-2">
                <i class="bi bi-bag-check-fill"></i>
                <span>Cart</span>
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success border-0 shadow-sm rounded-4 text-center mb-5">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger border-0 shadow-sm rounded-4 text-center mb-5">
            <i class="bi bi-exclamation-octagon-fill me-2"></i> @TempData["Error"]
        </div>
    }

    @if (Model.Produit == null || !Model.Produit.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-box-seam display-1 text-muted opacity-25"></i>
            <p class="mt-3 text-muted fw-bold">We couldn't find any products in this category.</p>
            <a href="?" class="btn btn-outline-primary rounded-pill mt-2">Clear Filters</a>
        </div>
    }
    else
    {
        <div class="row g-4 mb-5">
            @foreach (var item in Model.Produit)
            {
                <div class="col-sm-6 col-lg-4 col-xl-3">
                    <div class="product-card">
                        
                        <div class="img-wrapper">
                            <div class="card-badges">
                                @if (item.Category != null)
                                {
                                    <span class="badge-blur">@item.Category.Name</span>
                                }
                                <span class="badge-blur badge-stock" style="color: @(item.Stock < 5 ? "#e53e3e" : "#2f855a")">
                                    <i class="bi bi-box-seam me-1"></i> @item.Stock left
                                </span>
                            </div>

                            @if (!string.IsNullOrEmpty(item.ImageUrl))
                            {
                                <img src="@item.ImageUrl" alt="@item.Name" loading="lazy" />
                            }
                            else
                            {
                                <div class="placeholder-icon">
                                    <i class="bi bi-image"></i>
                                </div>
                            }
                        </div>

                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start">
                                <h5 class="product-title text-truncate">@item.Name</h5>
                            </div>
                            
                            <span class="price-tag">@item.Price.ToString("N2") €</span>
                            
                            <p class="product-desc">
                                @(item.Description != null && item.Description.Length > 60 
                                    ? item.Description.Substring(0, 60) + "..." 
                                    : item.Description)
                            </p>

                            <div class="mt-auto">
                                <form method="post" asp-page-handler="AddToCart" class="card-actions">
                                    <input type="hidden" name="productId" value="@item.ProduitId" />
                                    <input type="hidden" name="stock" value="@item.Stock" />
                                    
                                    <input type="number" name="quantity" value="1" min="1" max="@item.Stock" class="qty-input" aria-label="Quantity" />
                                    
                                    <button type="submit" class="btn-add-cart" @(item.Stock < 1 ? "disabled" : "")>
                                        @if(item.Stock > 0) {
                                            <span>Add to Cart</span> <i class="bi bi-arrow-right-short"></i>
                                        } else {
                                            <span>Sold Out</span>
                                        }
                                    </button>
                                </form>
                                <div class="text-center mt-2">
                                     <a asp-page="./Details" asp-route-id="@item.ProduitId" class="text-muted small text-decoration-none">View Details</a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>