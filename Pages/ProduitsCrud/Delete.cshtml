@page
@model WebApplication1.Pages.ProduitsCrud.DeleteModel

@{
    ViewData["Title"] = "Delete Product";
}

<h1 class="text-center mb-4 text-danger">Delete Product</h1>

<h4 class="text-center text-warning mb-3">Are you sure you want to delete this product?</h4>

<div class="row justify-content-center">
    <div class="col-md-7">

        <div class="card shadow-lg border-danger product-card">

            @if (!string.IsNullOrEmpty(Model.Produit.ImageUrl))
            {
                <img src="@Model.Produit.ImageUrl" class="card-img-top product-image" alt="@Model.Produit.Name" />
            }
            else
            {
                <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height:220px;">
                    <span class="text-muted">No Image Available</span>
                </div>
            }

            <div class="card-body">

                <h3 class="card-title mb-3">@Model.Produit.Name</h3>

                <p class="mb-2"><strong>Price:</strong> @Model.Produit.Price.ToString("C")</p>

                <p class="mb-2"><strong>Stock:</strong> <span class="badge bg-info">@Model.Produit.Stock</span></p>

                <p class="mb-2"><strong>Category:</strong> <span class="badge bg-secondary">@Model.Produit.Category?.Name</span></p>

                <p class="mt-3"><strong>Description:</strong><br />@Model.Produit.Description</p>

            </div>

            <div class="card-footer bg-white d-flex justify-content-between">

                <a asp-page="./Index" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left"></i> Back
                </a>

                <form method="post" class="mb-0">
                    <input type="hidden" asp-for="Produit.ProduitId" />
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash"></i> Delete
                    </button>
                </form>

            </div>

        </div>

    </div>
</div>

<style>
    .product-card {
        border-radius: 14px;
        overflow: hidden;
        transition: transform 0.15s ease, box-shadow 0.15s ease;
    }

    .product-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 6px 18px rgba(0,0,0,0.15);
    }

    .product-image {
        height: 260px;
        object-fit: cover;
    }

    .card-title {
        font-weight: 600;
        font-size: 1.7rem;
    }
</style>
