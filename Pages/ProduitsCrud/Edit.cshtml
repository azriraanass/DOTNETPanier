@page
@model WebApplication1.Pages.ProduitsCrud.EditModel

@{
    ViewData["Title"] = "Edit Product";
}

<h1 class="text-center mb-4">Edit Product</h1>

<div class="row justify-content-center">
    <div class="col-md-7">

        <div class="card shadow-lg border-0">
            <div class="card-header bg-primary text-white">
                <h4 class="mb-0"><i class="bi bi-pencil-square"></i> Update Product Details</h4>
            </div>

            <div class="card-body">

                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <input type="hidden" asp-for="Produit.ProduitId" />

                    <div class="mb-3">
                        <label asp-for="Produit.Name" class="form-label fw-bold"></label>
                        <input asp-for="Produit.Name" class="form-control" placeholder="Enter product name" />
                        <span asp-validation-for="Produit.Name" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Produit.Price" class="form-label fw-bold"></label>
                            <input asp-for="Produit.Price" class="form-control" placeholder="0.00" />
                            <span asp-validation-for="Produit.Price" class="text-danger"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="Produit.Stock" class="form-label fw-bold"></label>
                            <input asp-for="Produit.Stock" class="form-control" placeholder="Quantity in stock" />
                            <span asp-validation-for="Produit.Stock" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Produit.ImageUrl" class="form-label fw-bold"></label>
                        <input asp-for="Produit.ImageUrl" class="form-control" placeholder="https://image-url.com" />
                        <span asp-validation-for="Produit.ImageUrl" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Produit.Description" class="form-label fw-bold"></label>
                        <textarea asp-for="Produit.Description" class="form-control" rows="3" placeholder="Write a short description..."></textarea>
                        <span asp-validation-for="Produit.Description" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Produit.CategoryId" class="form-label fw-bold"></label>
                        <select asp-for="Produit.CategoryId" class="form-select" asp-items="ViewBag.CategoryId"></select>
                        <span asp-validation-for="Produit.CategoryId" class="text-danger"></span>
                    </div>

                    <div class="d-flex justify-content-between mt-4">
                        <a asp-page="./Index" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left"></i> Back
                        </a>

                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-save"></i> Save Changes
                        </button>
                    </div>

                </form>

            </div>
        </div>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

<style>
    .card {
        border-radius: 12px;
    }

    .card-header {
        border-top-left-radius: 12px !important;
        border-top-right-radius: 12px !important;
    }

    input.form-control, select.form-select, textarea.form-control {
        border-radius: 10px;
        padding: 10px 12px;
    }

        input.form-control:focus, select.form-select:focus, textarea.form-control:focus {
            box-shadow: 0 0 8px rgba(0, 123, 255, 0.25);
        }
</style>
