@page
@model WebApplication1.Pages.ProduitsCrud.DetailsModel

@{
    ViewData["Title"] = "Product Details";
}

<h1 class="text-center mb-4">Product Details</h1>

<div class="row justify-content-center">
    <div class="col-md-7">

        <div class="card shadow-lg border-0 product-card">

            @if (!string.IsNullOrEmpty(Model.Produit.ImageUrl))
            {
                <img src="@Model.Produit.ImageUrl" class="card-img-top product-image" alt="@Model.Produit.Name" />
            }
            else
            {
                <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height:220px;">
                    <span class="text-muted">No Image Available</span>
                </div>
            }

            <div class="card-body">

                <h3 class="card-title mb-3">@Model.Produit.Name</h3>

                <p class="mb-2">
                    <strong>Price:</strong> @Model.Produit.Price.ToString("C")
                </p>

                <p class="mb-2">
                    <strong>Stock:</strong> @Model.Produit.Stock
                </p>

                <p class="mb-2">
                    <strong>Category:</strong>
                    <span class="badge bg-secondary">@Model.Produit.Category?.Name</span>
                </p>

                <p class="mt-3">
                    <strong>Description:</strong><br />
                    @Model.Produit.Description
                </p>

            </div>

            <div class="card-footer bg-white d-flex justify-content-between">

                <a asp-page="./Index" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left"></i> Back
                </a>

                <a asp-page="./Edit" asp-route-id="@Model.Produit.ProduitId"
                   class="btn btn-primary">
                    <i class="bi bi-pencil-square"></i> Edit
                </a>

            </div>

        </div>

    </div>
</div>

<style>
    .product-card {
        border-radius: 14px;
        overflow: hidden;
    }

    .product-image {
        height: 260px;
        object-fit: cover;
    }

    .card-title {
        font-weight: 600;
        font-size: 1.7rem;
    }
</style>
