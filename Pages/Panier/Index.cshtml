@page
@model WebApplication1.Pages.Panier.IndexModel
@{
    ViewData["Title"] = "Votre Panier";
}

<style>
    :root {
        --primary-gradient: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        --primary-color: #764ba2;
        --secondary-bg: #f8f9fa;
        --glass-bg: rgba(255, 255, 255, 0.95);
        --shadow-soft: 0 10px 30px rgba(0,0,0,0.05);
        --shadow-hover: 0 20px 40px rgba(118, 75, 162, 0.15);
        --text-dark: #2d3748;
    }

    body {
        background-color: #f7fafc;
    }

    /* En-tête */
    .cart-header h1 {
        font-weight: 800;
        background: var(--primary-gradient);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        margin-bottom: 0.5rem;
    }

    /* Liste des articles (Gauche) */
    .cart-item-card {
        background: white;
        border-radius: 20px;
        padding: 1.5rem;
        margin-bottom: 1.5rem;
        border: 1px solid rgba(0,0,0,0.03);
        box-shadow: var(--shadow-soft);
        transition: all 0.3s ease;
        display: flex;
        flex-wrap: wrap; /* Pour mobile */
        align-items: center;
        gap: 1.5rem;
        position: relative;
        overflow: hidden;
    }

        .cart-item-card:hover {
            transform: translateY(-5px);
            box-shadow: var(--shadow-hover);
            border-color: rgba(118, 75, 162, 0.2);
        }

    .item-image-wrapper {
        width: 120px;
        height: 120px;
        border-radius: 15px;
        overflow: hidden;
        flex-shrink: 0;
        background-color: #edf2f7;
    }

        .item-image-wrapper img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.5s ease;
        }

    .cart-item-card:hover .item-image-wrapper img {
        transform: scale(1.1);
    }

    .item-details {
        flex-grow: 1;
        min-width: 200px;
    }

    .item-name {
        font-weight: 700;
        font-size: 1.2rem;
        color: var(--text-dark);
        margin-bottom: 0.5rem;
        text-decoration: none;
    }

    .item-price-unit {
        color: #718096;
        font-size: 0.9rem;
    }

    /* Contrôles Quantité */
    .qty-control-group {
        display: flex;
        align-items: center;
        background: #f1f5f9;
        border-radius: 50px;
        padding: 5px;
    }

    .qty-btn {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        border: none;
        background: white;
        color: var(--text-dark);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.2s;
        box-shadow: 0 2px 5px rgba(0,0,0,0.05);
    }

        .qty-btn:hover:not(:disabled) {
            background: var(--primary-color);
            color: white;
        }

        .qty-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

    .qty-display {
        width: 40px;
        text-align: center;
        font-weight: 700;
        font-size: 1rem;
        color: var(--text-dark);
    }

    /* Total par item */
    .item-total-price {
        font-weight: 800;
        font-size: 1.3rem;
        color: var(--primary-color);
        min-width: 100px;
        text-align: right;
    }

    /* Bouton Supprimer */
    .btn-remove {
        color: #e53e3e;
        background: rgba(229, 62, 62, 0.1);
        border: none;
        width: 40px;
        height: 40px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s;
    }

        .btn-remove:hover {
            background: #e53e3e;
            color: white;
            transform: rotate(90deg);
        }

    /* Résumé de commande (Droite) */
    .order-summary {
        background: var(--primary-gradient);
        border-radius: 20px;
        padding: 2rem;
        color: white;
        position: sticky;
        top: 20px;
        box-shadow: 0 20px 50px rgba(118, 75, 162, 0.3);
    }

    .summary-row {
        display: flex;
        justify-content: space-between;
        margin-bottom: 1rem;
        font-size: 0.95rem;
        opacity: 0.9;
    }

    .summary-total {
        border-top: 1px solid rgba(255,255,255,0.2);
        margin-top: 1.5rem;
        padding-top: 1.5rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .total-label {
        font-size: 1.1rem;
        font-weight: 600;
    }

    .total-amount {
        font-size: 2rem;
        font-weight: 800;
    }

    .btn-checkout {
        background: white;
        color: var(--primary-color);
        width: 100%;
        padding: 1rem;
        border-radius: 15px;
        font-weight: 800;
        font-size: 1.1rem;
        border: none;
        margin-top: 2rem;
        transition: transform 0.2s;
        box-shadow: 0 10px 20px rgba(0,0,0,0.2);
    }

        .btn-checkout:hover {
            transform: translateY(-3px);
        }

    .btn-continue {
        color: white;
        text-decoration: none;
        display: block;
        text-align: center;
        margin-top: 1rem;
        font-size: 0.9rem;
        opacity: 0.8;
    }

        .btn-continue:hover {
            opacity: 1;
            text-decoration: underline;
        }

    /* Empty State */
    .empty-cart {
        text-align: center;
        padding: 5rem 2rem;
    }

    @@media (max-width: 768px) {
        .item-details {
            width: 100%;
            order: 2;
            text-align: center;
        }

        .item-image-wrapper {
            width: 100%;
            height: 200px;
            margin-bottom: 1rem;
        }

        .qty-control-group {
            margin: 1rem auto;
        }

        .item-total-price {
            width: 100%;
            text-align: center;
            margin-bottom: 1rem;
        }

        .btn-remove {
            position: absolute;
            top: 1rem;
            right: 1rem;
            background: white;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        }
    }
</style>

<div class="container py-5">

    <div class="cart-header text-center mb-5">
        <h1>Shopping Cart</h1>
        <p class="text-muted">
            You have <span class="fw-bold text-primary">@Model.CartItems.Sum(i => i.Quantity) items</span> in your cart
        </p>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success border-0 shadow-sm rounded-4 d-flex align-items-center mb-4">
            <i class="bi bi-check-circle-fill me-3 fs-4"></i>
            <div>@TempData["Success"]</div>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger border-0 shadow-sm rounded-4 d-flex align-items-center mb-4">
            <i class="bi bi-exclamation-triangle-fill me-3 fs-4"></i>
            <div>@TempData["Error"]</div>
        </div>
    }

    @if (!Model.CartItems.Any())
    {
        <div class="empty-cart">
            <i class="bi bi-cart-x display-1 text-muted opacity-25 mb-3"></i>
            <h3 class="fw-bold">Your cart is empty</h3>
            <p class="text-muted mb-4">Looks like you haven't added anything to your cart yet.</p>
            <a href="/Produits/Index" class="btn btn-primary rounded-pill px-5 py-3 fw-bold shadow">
                Start Shopping
            </a>
        </div>
    }
    else
    {
        <div class="row g-5">
            <div class="col-lg-8">

                <div class="d-flex justify-content-between align-items-center mb-3 px-2">
                    <span class="text-uppercase small fw-bold text-muted tracking-wide">Product Details</span>

                    <form method="post" asp-page-handler="ViderPanier" class="d-inline">
                        <button type="submit" class="btn btn-link text-danger text-decoration-none p-0 small"
                                onclick="return confirm('Are you sure you want to clear your cart?')">
                            <i class="bi bi-trash"></i> Clear All
                        </button>
                    </form>
                </div>

                @foreach (var item in Model.CartItems)
                {
                    <div class="cart-item-card">

                        <div class="item-image-wrapper">
                            @if (!string.IsNullOrEmpty(item.Produit.ImageUrl))
                            {
                                <img src="@item.Produit.ImageUrl" alt="@item.Produit.Name" />
                            }
                            else
                            {
                                <div class="d-flex align-items-center justify-content-center h-100 text-muted bg-light">
                                    <i class="bi bi-image fs-3"></i>
                                </div>
                            }
                        </div>

                        <div class="item-details">
                            <div class="item-name">@item.Produit.Name</div>
                            <div class="item-price-unit">Unit Price: @item.Produit.Price.ToString("F2") €</div>
                        </div>

                        <form method="post" asp-page-handler="UpdateQuantity" class="d-flex align-items-center">
                            <input type="hidden" name="productId" value="@item.Produit.ProduitId" />

                            <div class="qty-control-group">
                                <button type="submit" name="action" value="decrease" class="qty-btn" @(item.Quantity <= 1 ? "disabled" : "")>
                                    <i class="bi bi-dash"></i>
                                </button>

                                <span class="qty-display">@item.Quantity</span>

                                <button type="submit" name="action" value="increase" class="qty-btn">
                                    <i class="bi bi-plus"></i>
                                </button>
                            </div>
                        </form>

                        <div class="item-total-price">
                            @item.TotalPrice.ToString("F2") <small style="font-size:0.7em">€</small>
                        </div>

                        <form method="post" asp-page-handler="RemoveItem" class="ms-md-3">
                            <input type="hidden" name="productId" value="@item.Produit.ProduitId" />
                            <button type="submit" class="btn-remove" title="Remove Item">
                                <i class="bi bi-x-lg"></i>
                            </button>
                        </form>
                    </div>
                }
            </div>

            <div class="col-lg-4">
                <div class="order-summary">
                    <h3 class="fw-bold mb-4">Order Summary</h3>

                    <div class="summary-row">
                        <span>Subtotal</span>
                        <span>@Model.TotalGeneral.ToString("F2") €</span>
                    </div>
                    <div class="summary-row">
                        <span>Shipping Estimate</span>
                        <span>Free</span>
                    </div>
                    <div class="summary-row">
                        <span>Tax Estimate</span>
                        <span>Included</span>
                    </div>

                    <div class="summary-total">
                        <span class="total-label">Total</span>
                        <span class="total-amount">@Model.TotalGeneral.ToString("F2") <span class="fs-6">€</span></span>
                    </div>

                    <button class="btn-checkout">
                        Checkout Now <i class="bi bi-arrow-right-short"></i>
                    </button>

                    <a href="/Produits/Index" class="btn-continue">
                        Continue Shopping
                    </a>
                </div>

                <div class="mt-4 text-center text-muted opacity-75">
                    <small><i class="bi bi-shield-lock-fill"></i> Secure Checkout</small>
                    <div class="mt-2 fs-4 gap-2 d-flex justify-content-center">
                        <i class="bi bi-credit-card"></i>
                        <i class="bi bi-paypal"></i>
                        <i class="bi bi-apple"></i>
                    </div>
                </div>
            </div>
        </div>
    }
</div>