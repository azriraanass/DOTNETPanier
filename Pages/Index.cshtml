@page
@model IndexModel
@using Microsoft.AspNetCore.Antiforgery
@inject IAntiforgery Xsrf
@{
    ViewData["Title"] = "Home Page";
}

<style>
    :root {
        --primary-gradient: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        --primary-color: #764ba2;
        --secondary-color: #1a1b1f;
        --accent-color: #f4f7ff;
        --card-shadow: 0 10px 20px rgba(0,0,0,0.05);
    }

    /* --- Hero Section --- */
    .hero-section {
        background: var(--primary-gradient);
        color: white;
        padding: 5rem 2rem;
        border-radius: 20px;
        margin-bottom: 4rem;
        position: relative;
        overflow: hidden;
        box-shadow: 0 20px 40px rgba(118, 75, 162, 0.2);
    }

    .hero-pattern {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        opacity: 0.1;
        background-image: radial-gradient(#fff 1px, transparent 1px);
        background-size: 20px 20px;
    }

    .hero-content {
        position: relative;
        z-index: 2;
    }

    .hero-btn {
        background: white;
        color: var(--primary-color);
        padding: 12px 35px;
        border-radius: 50px;
        font-weight: 700;
        text-decoration: none;
        transition: all 0.3s ease;
        display: inline-block;
        margin-top: 1.5rem;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    }

        .hero-btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.2);
            color: var(--primary-color);
        }

    /* --- Features & Cards --- */
    .section-title {
        font-weight: 800;
        margin-bottom: 2rem;
        position: relative;
        display: inline-block;
    }

        .section-title::after {
            content: '';
            display: block;
            width: 50%;
            height: 4px;
            background: var(--primary-color);
            border-radius: 2px;
            margin-top: 5px;
        }

    .feature-box {
        text-align: center;
        padding: 2rem;
        border-radius: 15px;
        background: white;
        box-shadow: var(--card-shadow);
        transition: transform 0.3s ease;
        height: 100%;
    }

        .feature-box:hover {
            transform: translateY(-5px);
        }

    .feature-icon {
        font-size: 2.5rem;
        color: var(--primary-color);
        margin-bottom: 1rem;
    }

    .custom-card {
        border: none;
        border-radius: 15px;
        overflow: hidden;
        box-shadow: var(--card-shadow);
        transition: all 0.3s ease;
        height: 100%;
        background: white;
    }

        .custom-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.1);
        }

    .card-img-wrapper {
        height: 220px;
        overflow: hidden;
        position: relative;
    }

        .card-img-wrapper img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.5s ease;
        }

    .custom-card:hover .card-img-wrapper img {
        transform: scale(1.1);
    }

    .card-badge {
        position: absolute;
        top: 15px;
        right: 15px;
        background: rgba(255,255,255,0.9);
        backdrop-filter: blur(5px);
        color: var(--primary-color);
        padding: 5px 15px;
        border-radius: 20px;
        font-weight: 700;
        font-size: 0.8rem;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    }

    /* --- Chat Styles --- */
    .chat-bubble-user {
        background: var(--primary-color);
        color: white;
        border-radius: 15px 15px 0 15px;
    }

    .chat-bubble-ai {
        background: white;
        color: #333;
        border-radius: 15px 15px 15px 0;
        box-shadow: 0 2px 5px rgba(0,0,0,0.05);
    }
</style>

<div class="container py-4">

    <div class="hero-section text-center text-md-start d-flex align-items-center">
        <div class="hero-pattern"></div>
        <div class="row w-100 p-3 hero-content">
            <div class="col-lg-7">
                <span class="badge bg-white text-primary mb-3 px-3 py-2 rounded-pill">New Collection 2024</span>
                <h1 class="display-3 fw-bolder mb-3">Upgrade Your <br />Digital Life</h1>
                <p class="lead mb-4 opacity-75" style="font-weight: 300;">
                    Experience the future today with our curated selection of high-end electronics.
                </p>
                <a asp-page="/Produits/Index" class="hero-btn">Shop Now <i class="bi bi-arrow-right ms-2"></i></a>
            </div>
            <div class="col-lg-5 d-none d-lg-block text-center position-relative">
                <i class="bi bi-laptop display-1 text-white opacity-25" style="font-size: 10rem;"></i>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-md-4"><div class="feature-box"><i class="bi bi-truck feature-icon"></i><h5>Free Shipping</h5><p class="text-muted small">On all orders over 500€.</p></div></div>
        <div class="col-md-4"><div class="feature-box"><i class="bi bi-shield-check feature-icon"></i><h5>2 Year Warranty</h5><p class="text-muted small">Comprehensive coverage.</p></div></div>
        <div class="col-md-4"><div class="feature-box"><i class="bi bi-headset feature-icon"></i><h5>24/7 Support</h5><p class="text-muted small">Experts are here to help.</p></div></div>
    </div>

    <div class="mb-5">
        <h2 class="section-title">Editor's Picks</h2>
        @if (Model.FeaturedProducts != null && Model.FeaturedProducts.Any())
        {
            <div class="row g-4 mt-2">
                @foreach (var item in Model.FeaturedProducts)
                {
                    <div class="col-md-4">
                        <div class="custom-card">
                            <div class="card-img-wrapper">
                                <span class="card-badge">Top Rated</span>
                                @if (!string.IsNullOrEmpty(item.ImageUrl))
                                {
                                    <img src="@item.ImageUrl" alt="@item.Name">
                                }
                                else
                                {
                                    <div class="d-flex align-items-center justify-content-center h-100 bg-secondary text-white">No Image</div>
                                }
                            </div>
                            <div class="p-4">
                                <h5 class="fw-bold">@item.Name</h5>
                                <div class="d-flex justify-content-between align-items-center mt-3">
                                    <span class="h5 mb-0 text-primary">@item.Price.ToString("N2") €</span>
                                    <a asp-page="/Produits/Details" asp-route-id="@item.ProduitId" class="btn btn-sm btn-outline-dark rounded-pill">View</a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <p class="text-center text-muted">No featured products found.</p>
        }
    </div>

    @if (Model.NewArrivals != null && Model.NewArrivals.Any())
    {
        <div class="mb-5">
            <div class="d-flex justify-content-between align-items-end mb-4">
                <h2 class="section-title mb-0">New Arrivals</h2>
                <a asp-page="/Produits/Index" class="text-decoration-none fw-bold">View All <i class="bi bi-arrow-right"></i></a>
            </div>
            <div class="row g-4">
                @foreach (var item in Model.NewArrivals)
                {
                    <div class="col-6 col-md-3">
                        <div class="custom-card h-100">
                            <div class="card-img-wrapper" style="height: 180px;">
                                @if (!string.IsNullOrEmpty(item.ImageUrl))
                                {
                                    <img src="@item.ImageUrl" alt="@item.Name" />
                                }
                                else
                                {
                                    <div class="d-flex align-items-center justify-content-center h-100 bg-light text-muted"><i class="bi bi-image fs-1"></i></div>
                                }
                            </div>
                            <div class="p-3 d-flex flex-column h-100">
                                <h6 class="fw-bold text-truncate">@item.Name</h6>
                                <div class="mt-auto d-flex justify-content-between align-items-center">
                                    <span class="fw-bold text-dark">@item.Price.ToString("N2") €</span>
                                    <a asp-page="/Produits/Details" asp-route-id="@item.ProduitId" class="btn btn-sm btn-light rounded-circle"><i class="bi bi-plus-lg"></i></a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    