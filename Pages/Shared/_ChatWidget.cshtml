@using WebApplication1.Models
@using Microsoft.AspNetCore.Antiforgery
@inject IAntiforgery Xsrf
@{
    // Retrieve history from ViewData, or use a new list if empty
    var history = ViewData["ChatHistory"] as List<MessageLine> ?? new List<MessageLine>();
}

<style>
    .chat-widget-container {
        position: fixed;
        bottom: 20px;
        right: 20px;
        z-index: 9999;
        width: 350px;
        display: flex;
        flex-direction: column;
        align-items: flex-end;
    }

    #chat-window {
        width: 100%;
        height: 450px;
        display: none;
        flex-direction: column;
        background: white;
        border-radius: 15px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
        overflow: hidden;
        margin-bottom: 15px;
    }

    .chat-toggle-btn {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        background: linear-gradient(90deg, #ff7e5f, #feb47b);
        color: white;
        border: none;
        cursor: pointer;
        box-shadow: 0 5px 15px rgba(0,0,0,0.2);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
    }

    .chat-body-scroll {
        flex: 1;
        overflow-y: auto;
        padding: 15px;
        background: #f8f9fa;
        display: flex;
        flex-direction: column;
    }

    .chat-bubble-user {
        background: #ff7e5f;
        color: white;
        border-radius: 15px 15px 0 15px;
        padding: 8px 12px;
        margin-bottom: 10px;
        align-self: flex-end;
        max-width: 85%;
    }

    .chat-bubble-ai {
        background: #eee;
        color: #333;
        border-radius: 15px 15px 15px 0;
        padding: 8px 12px;
        margin-bottom: 10px;
        align-self: flex-start;
        max-width: 85%;
    }
</style>

<div class="chat-widget-container">
    <div id="chat-window" class="card shadow-lg border-0">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
            <h6 class="mb-0"><i class="bi bi-stars text-warning me-2"></i>Grok Assistant</h6>
            <button type="button" class="btn-close btn-close-white" onclick="toggleChat()"></button>
        </div>

        <div id="chat-body" class="chat-body-scroll">
            @if (history.Count > 0)
            {
                @foreach (var msg in history)
                {
                    <div class="@(msg.Role == "User" ? "chat-bubble-user" : "chat-bubble-ai")">
                        @msg.Text
                    </div>
                }
            }
            else
            {
                <div class="text-center text-muted mt-5" id="empty-chat-msg">
                    <i class="bi bi-robot display-4 mb-3"></i>
                    <p>Hello! Ask me anything.</p>
                </div>
            }
        </div>

        <div class="card-footer bg-white border-0 p-3">
            <div class="input-group">
                <input type="text" id="chatInput" class="form-control" placeholder="Type message...">
                <button class="btn btn-primary" onclick="sendWidgetMessage()"><i class="bi bi-send-fill"></i></button>
            </div>
        </div>
    </div>

    <button class="chat-toggle-btn" onclick="toggleChat()">
        <i class="bi bi-chat-dots-fill"></i>
    </button>
</div>

<script>
    function toggleChat() {
        const win = document.getElementById('chat-window');
        win.style.display = (win.style.display === 'none' || win.style.display === '') ? 'flex' : 'none';
        if(win.style.display === 'flex') {
            const body = document.getElementById('chat-body');
            body.scrollTop = body.scrollHeight;
        }
    }

    async function sendWidgetMessage() {
        const input = document.getElementById('chatInput');
        const text = input.value.trim();
        if (!text) return;

        const empty = document.getElementById('empty-chat-msg');
        if(empty) empty.style.display = 'none';

        appendBubble("User", text);
        input.value = '';

        try {
            const response = await fetch('/Index?handler=SendMessage', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': '@Xsrf.GetAndStoreTokens(Context).RequestToken'
                },
                body: JSON.stringify({ userMessage: text })
            });

            const data = await response.json();
            appendBubble("Grok", data.reply);
        } catch (err) {
            console.error("Chat Error:", err);
        }
    }

    function appendBubble(role, text) {
        const body = document.getElementById('chat-body');
        const isUser = role === "User";
        const div = document.createElement('div');
        div.className = isUser ? 'chat-bubble-user' : 'chat-bubble-ai';
        div.innerText = text;
        body.appendChild(div);
        body.scrollTop = body.scrollHeight;
    }
</script>